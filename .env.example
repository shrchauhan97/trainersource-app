# Supabase — required for the app to boot.
# The NEXT_PUBLIC_ vars are read by the browser-facing Supabase SSR client.
# SUPABASE_URL / SUPABASE_ANON_KEY are also read by server-only code paths
# (webhook handler, integration tests) and fall back to the NEXT_PUBLIC_ values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BigCommerce API — customer sync + order fetches from the webhook handler.
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_ACCESS_TOKEN=

# BigCommerce webhook auth — MUST be a separate, dedicated secret.
# Do NOT reuse BIGCOMMERCE_ACCESS_TOKEN here.
# Configure the BC webhook destination with either:
#   (a) Authorization: Bearer <this-value>, or
#   (b) HMAC signing key (X-BC-Webhook-Signature header) set to <this-value>.
BIGCOMMERCE_WEBHOOK_SECRET=

# Access gate CORS allowlist — comma-separated origins.
# Defaults to https://ultimate-peptides.com when unset.
ACCESS_GATE_ALLOWED_ORIGINS=https://ultimate-peptides.com

# Access gate session token — HMAC secret used to sign the session tokens
# handed to the storefront after a successful code validation. The storefront
# stores the token in localStorage; every page load it calls /api/session/check
# which verifies the signature + checks the customer still exists. Without a
# secret here, anyone can set localStorage and bypass the gate (review finding
# C2). Use ≥32 chars of randomness, e.g. `openssl rand -base64 48`.
ACCESS_GATE_SESSION_SECRET=

# Wise (payouts)
WISE_API_KEY=
WISE_PROFILE_ID=

# App
NEXT_PUBLIC_SITE_URL=https://trainersource.com

# Dev-only: enables GET /api/dev/login?email=...&password=...&redirect=... so
# you can sign in with password during local walkthroughs without the magic-link
# email detour. Set to 1 ONLY in local dev environments. The route also refuses
# to run when NODE_ENV=production, but keep this flag off in any shared env.
ENABLE_DEV_LOGIN=
